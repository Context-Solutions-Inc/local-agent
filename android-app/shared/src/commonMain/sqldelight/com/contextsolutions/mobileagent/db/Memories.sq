-- Memory store per PRD section 3.2.4. Embeddings stored as BLOB; brute-force cosine
-- similarity over up to ~1,000 entries is sub-10ms on Pixel 7 — no native vector index needed.
--
-- M5 adds the `access_count` column to support PRD §3.2.4's "LRU + access-frequency
-- heuristic" eviction tier. Existing dev installs from M0/M1/M2 must be wiped
-- before this schema lands (no migration support is wired up yet — followup for M6).
--
-- TELEMETRY EXCLUSION (PRD §4.4 + WS-12): The contents of this table — memory `text`,
-- `embedding` BLOBs, `conversation_id` — must NEVER flow into the M6 WS-13 opt-in
-- telemetry payload. Aggregate counters only (e.g., total memory count, evictions per
-- day, retrievals per day). When the telemetry builder lands in M6, gate it on a
-- contract-level review that this table is not read.

CREATE TABLE memories (
    id TEXT NOT NULL PRIMARY KEY,
    text TEXT NOT NULL,
    category TEXT NOT NULL,                   -- personal_identity, preference, professional, interest, relationship, temporary_context
    conversation_id TEXT,                     -- FK soft-reference (memory may outlive its source conversation)
    created_at_epoch_ms INTEGER NOT NULL,
    last_accessed_epoch_ms INTEGER NOT NULL,
    access_count INTEGER NOT NULL DEFAULT 0,  -- bumped on retrieval hit; tier-3 eviction key
    embedding BLOB NOT NULL,                  -- 384-dim float32 little-endian (1,536 bytes) for all-MiniLM-L6-v2
    expires_at_epoch_ms INTEGER               -- NULL for non-expiring memories
);

CREATE INDEX memories_by_category ON memories(category);
CREATE INDEX memories_by_conversation ON memories(conversation_id);
CREATE INDEX memories_by_expires ON memories(expires_at_epoch_ms) WHERE expires_at_epoch_ms IS NOT NULL;
CREATE INDEX memories_by_last_accessed ON memories(last_accessed_epoch_ms);

-- -- Inserts -----------------------------------------------------------------

insertMemory:
INSERT INTO memories(
    id, text, category, conversation_id, created_at_epoch_ms,
    last_accessed_epoch_ms, access_count, embedding, expires_at_epoch_ms
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

-- -- Reads ------------------------------------------------------------------

-- Retrieval candidates: all non-expired rows with their embeddings. The Kotlin
-- side computes cosine similarity in process and returns top-K above a
-- threshold. Used by MemoryStore.retrieveTopK and findCosineMatch / deleteByCosine.
selectAllNonExpiredWithEmbedding:
SELECT * FROM memories
WHERE expires_at_epoch_ms IS NULL OR expires_at_epoch_ms > ?;

-- Used by both findCosineMatch (Phase D dedup) and deleteByCosine (Phase D
-- forget-command path). Same row set as selectAllNonExpiredWithEmbedding.
-- Kept as a separate named query so the read intent is documented at call
-- sites.
selectAllForCosineSearch:
SELECT * FROM memories
WHERE expires_at_epoch_ms IS NULL OR expires_at_epoch_ms > ?;

-- Per-conversation memory list (UI: ConversationMemoryListScreen). Newest first.
selectByConversationId:
SELECT * FROM memories
WHERE conversation_id = ?
ORDER BY created_at_epoch_ms DESC;

-- Per-conversation count (UI: ConversationMemoryBadge).
countByConversationId:
SELECT COUNT(*) FROM memories WHERE conversation_id = ?;

-- Full inventory (UI: MemoryScreen — grouped by category in the ViewModel).
selectAllMemories:
SELECT * FROM memories ORDER BY created_at_epoch_ms DESC;

-- Non-expired count (eviction pre-insert gate).
countNonExpired:
SELECT COUNT(*) FROM memories
WHERE expires_at_epoch_ms IS NULL OR expires_at_epoch_ms > ?;

-- Total row count regardless of expiry — used by `deleteExpired` to compute
-- how many rows it just removed (the DELETE itself doesn't return a count).
countAll:
SELECT COUNT(*) FROM memories;

-- -- Mutations -------------------------------------------------------------

-- Atomic last-accessed bump + access_count++. Run on retrieval hits and
-- explicit user views in the management UI.
incrementAccessAndUpdateLastAccessed:
UPDATE memories
SET last_accessed_epoch_ms = ?, access_count = access_count + 1
WHERE id = ?;

-- Delete a single memory by primary key.
deleteMemory:
DELETE FROM memories WHERE id = ?;

-- Tier 1 eviction sweep — drop everything past expiry.
deleteExpiredMemories:
DELETE FROM memories
WHERE expires_at_epoch_ms IS NOT NULL AND expires_at_epoch_ms <= ?;

-- Tier 2/3 eviction candidate list. Tier 2 passes a recency cutoff
-- (`now - 90d`) and an effectively unbounded limit; tier 3 passes
-- Long.MIN_VALUE-ish for the cutoff (matching every row) and a small
-- positive limit. Ordering favors least-recently-accessed first, then
-- least-frequently-accessed as the tie-break — PRD §3.2.4
-- "LRU + access-frequency heuristic".
selectLruEvictionCandidates:
SELECT id FROM memories
WHERE last_accessed_epoch_ms < ?
ORDER BY last_accessed_epoch_ms ASC, access_count ASC
LIMIT ?;

-- Delete everything (UI: MemoryScreen "Clear all"). No filtering — the user
-- has confirmed.
deleteAllMemories:
DELETE FROM memories;
