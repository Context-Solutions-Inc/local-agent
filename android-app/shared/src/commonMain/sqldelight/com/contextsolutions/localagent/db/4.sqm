-- Migration v4 -> v5 (PR #15, TODO list feature).
--
-- Adds a fresh `todos` table for the on-device TODO list — no ALTERs to
-- existing tables. Column order matches Todos.sq exactly so
-- verifyMigrations doesn't flag drift between Schema.create() (fresh
-- installs at v5) and Schema.migrate() (upgrades from v4 to v5).

CREATE TABLE todos (
    id TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    priority TEXT NOT NULL,
    due_date_epoch_ms INTEGER,
    completed INTEGER NOT NULL DEFAULT 0,
    created_at_epoch_ms INTEGER NOT NULL,
    updated_at_epoch_ms INTEGER NOT NULL,
    notes TEXT
);

CREATE INDEX todos_by_completed_due ON todos(completed, due_date_epoch_ms);
