-- Conversations and messages.
-- Schema is intentionally minimal in M0; M1 (chat MVP) extends with indexes and
-- additional columns (token counts, model metadata, etc.).
--
-- truncation_acknowledged_at added in 3.sqm (PR#13). NULL until the user
-- confirms the "oldest pair will be dropped" warning for this conversation;
-- non-null thereafter so subsequent overflows truncate silently.

-- deleted_at_epoch_ms added in 8.sqm (PR #57): soft-delete tombstone for sync.
-- NULL = live; non-null = the epoch-ms the row was deleted. Appended at the END
-- so Schema.create() matches Schema.migrate() (invariant #20). All UI/read
-- queries filter `deleted_at_epoch_ms IS NULL`; the *ChangedSince sync queries
-- deliberately include tombstoned rows so deletes propagate to the peer.
CREATE TABLE conversations (
    id TEXT NOT NULL PRIMARY KEY,
    title TEXT NOT NULL,
    created_at_epoch_ms INTEGER NOT NULL,
    updated_at_epoch_ms INTEGER NOT NULL,
    truncation_acknowledged_at INTEGER,
    deleted_at_epoch_ms INTEGER
);

CREATE TABLE messages (
    id TEXT NOT NULL PRIMARY KEY,
    conversation_id TEXT NOT NULL REFERENCES conversations(id) ON DELETE CASCADE,
    role TEXT NOT NULL,                       -- 'user' | 'assistant' | 'tool' | 'system'
    content TEXT NOT NULL,
    tool_call_json TEXT,                      -- function call payload when role='assistant' emits one
    tool_result_json TEXT,                    -- when role='tool'
    created_at_epoch_ms INTEGER NOT NULL,
    sequence_index INTEGER NOT NULL,          -- monotonically increasing within conversation
    image_bytes BLOB,                         -- 5.sqm (PR #49): downscaled JPEG, display-only; never re-fed to the model
    render_markdown INTEGER NOT NULL DEFAULT 1, -- 6.sqm (PR #50): 1 = render markdown+LaTeX, 0 = plain (weather/finance cards)
    deleted_at_epoch_ms INTEGER               -- 11.sqm (PR #4): soft-delete tombstone for per-turn delete; NULL = live
);

CREATE INDEX messages_by_conversation ON messages(conversation_id, sequence_index);

insertConversation:
INSERT INTO conversations(id, title, created_at_epoch_ms, updated_at_epoch_ms, truncation_acknowledged_at)
VALUES (?, ?, ?, ?, NULL);

selectAllConversations:
SELECT * FROM conversations WHERE deleted_at_epoch_ms IS NULL ORDER BY updated_at_epoch_ms DESC;

selectRecentConversations:
SELECT * FROM conversations WHERE deleted_at_epoch_ms IS NULL ORDER BY updated_at_epoch_ms DESC LIMIT :limit;

selectConversationById:
SELECT * FROM conversations WHERE id = ? AND deleted_at_epoch_ms IS NULL;

-- PR #8: full-content search for the Manage Conversations screen. Matches the
-- query against the title OR any live user/assistant message body (tool/system
-- rows excluded, mirroring selectLastMessagePreview). Both soft-delete
-- tombstones (#68) are honoured. No FTS index — the CONVERSATION_CAP (50) keeps
-- this LIKE scan trivially fast, so nothing changes in the save path. :q is a
-- bound parameter (injection-safe); the % wildcards are concatenated in SQL so
-- the caller passes the raw term.
searchConversations:
SELECT DISTINCT conversations.* FROM conversations
JOIN messages ON messages.conversation_id = conversations.id
WHERE conversations.deleted_at_epoch_ms IS NULL
  AND messages.deleted_at_epoch_ms IS NULL
  AND messages.role IN ('user', 'assistant')
  AND (conversations.title LIKE '%' || :q || '%' OR messages.content LIKE '%' || :q || '%')
ORDER BY conversations.updated_at_epoch_ms DESC
LIMIT :limit;

countConversations:
SELECT COUNT(*) FROM conversations WHERE deleted_at_epoch_ms IS NULL;

selectOldestConversationIds:
SELECT id FROM conversations WHERE deleted_at_epoch_ms IS NULL ORDER BY updated_at_epoch_ms ASC LIMIT :limit;

deleteConversation:
DELETE FROM conversations WHERE id = ?;

-- PR #57 sync: soft-delete (tombstone) instead of a hard DELETE so the delete
-- propagates to the paired device. Bumps updated_at so it rides the change feed.
softDeleteConversation:
UPDATE conversations SET deleted_at_epoch_ms = :nowEpochMs, updated_at_epoch_ms = :nowEpochMs WHERE id = :id;

touchUpdatedAt:
UPDATE conversations SET updated_at_epoch_ms = :nowEpochMs WHERE id = :id;

-- PR #57 sync: change feed (includes tombstoned rows so deletes propagate).
selectConversationsChangedSince:
SELECT * FROM conversations WHERE updated_at_epoch_ms > :since ORDER BY updated_at_epoch_ms ASC;

-- PR #57 sync: last-write-wins upsert from a peer. ON CONFLICT...DO UPDATE (not
-- INSERT OR REPLACE — REPLACE would delete+reinsert the row and cascade-delete
-- its messages). The WHERE guard only applies the peer's row when it is newer.
-- created_at is never overwritten (the original creation time is authoritative).
upsertConversationFromPeer:
INSERT INTO conversations(id, title, created_at_epoch_ms, updated_at_epoch_ms, truncation_acknowledged_at, deleted_at_epoch_ms)
VALUES (:id, :title, :createdAt, :updatedAt, :truncationAck, :deletedAt)
ON CONFLICT(id) DO UPDATE SET
    title = excluded.title,
    updated_at_epoch_ms = excluded.updated_at_epoch_ms,
    truncation_acknowledged_at = excluded.truncation_acknowledged_at,
    deleted_at_epoch_ms = excluded.deleted_at_epoch_ms
WHERE excluded.updated_at_epoch_ms > conversations.updated_at_epoch_ms;

acknowledgeTruncation:
UPDATE conversations SET truncation_acknowledged_at = :nowEpochMs WHERE id = :id;

insertMessage:
INSERT INTO messages(id, conversation_id, role, content, tool_call_json, tool_result_json, created_at_epoch_ms, sequence_index, image_bytes, render_markdown)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- PR #57 sync: messages are immutable + keyed by UUID, so a peer's message is
-- unioned in by id. Content columns are never updated (immutable); the ONLY
-- mutable field is the PR #4 soft-delete tombstone, which is propagated with
-- "tombstone wins, no resurrection": a peer's deleted_at is applied iff we
-- haven't already deleted the row, and a NULL deleted_at can never clear an
-- existing tombstone. New rows insert as usual.
upsertMessageFromPeer:
INSERT INTO messages(id, conversation_id, role, content, tool_call_json, tool_result_json, created_at_epoch_ms, sequence_index, image_bytes, render_markdown, deleted_at_epoch_ms)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
ON CONFLICT(id) DO UPDATE SET
    deleted_at_epoch_ms = excluded.deleted_at_epoch_ms
WHERE excluded.deleted_at_epoch_ms IS NOT NULL AND messages.deleted_at_epoch_ms IS NULL;

-- Raw read incl. tombstoned rows: used by the sync bundle (so deletes
-- propagate) and by sequence-index computation (so a new message after a
-- delete never reuses a tombstoned row's index).
selectMessagesByConversation:
SELECT * FROM messages WHERE conversation_id = ? ORDER BY sequence_index ASC;

-- Live read (tombstones excluded): the UI bubble list + agent history.
selectActiveMessagesByConversation:
SELECT * FROM messages WHERE conversation_id = ? AND deleted_at_epoch_ms IS NULL ORDER BY sequence_index ASC;

deleteMessagesBelowSequence:
DELETE FROM messages
WHERE conversation_id = :conversationId AND sequence_index < :cutoffSequenceIndex;

-- PR #4: soft-delete (tombstone) a whole turn — the contiguous run of rows
-- [startSeq, endSeq) from a user message up to (excluding) the next user
-- message. Idempotent (already-tombstoned rows are skipped).
softDeleteMessagesInRange:
UPDATE messages SET deleted_at_epoch_ms = :nowEpochMs
WHERE conversation_id = :conversationId
  AND sequence_index >= :startSeq AND sequence_index < :endSeq
  AND deleted_at_epoch_ms IS NULL;

selectLastMessagePreview:
SELECT content FROM messages
WHERE conversation_id = :conversationId AND role IN ('user', 'assistant') AND deleted_at_epoch_ms IS NULL
ORDER BY sequence_index DESC
LIMIT 1;
