<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- Required by Compose Multiplatform (androidx.compose.ui.uikit.PlistSanityCheck):
	     enables full refresh rate on ProMotion iPhones. Missing/false → the app throws
	     IllegalStateException on launch. -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Phone-focused single-window UI; opts out of iPad multitasking so the limited
	     orientation set above is valid (silences the "All interface orientations must
	     be supported unless the app requires full screen" warning). -->
	<key>UIRequiresFullScreen</key>
	<true/>
	<!-- Read by IosAppBuildConfig.gitDescribe (About dialog). Optional; set at build time. -->
	<key>LocalAgentGitDescribe</key>
	<string>ios-dev</string>
	<!-- Voice I/O (Phase 2): mic dictation via SFSpeechRecognizer. iOS crashes the
	     permission prompt without these usage descriptions. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Local Agent uses the microphone for voice dictation so you can talk to the assistant.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Local Agent transcribes your speech on device (when supported) to turn what you say into chat messages.</string>
	<!-- Image input (Phase 3, PR #44): in-app camera capture via UIImagePickerController.
	     iOS crashes when the camera is accessed without this usage description. -->
	<key>NSCameraUsageDescription</key>
	<string>Local Agent uses the camera so you can take a photo to ask the assistant about.</string>
</dict>
</plist>
