# Copy this file to `secrets.properties` (gitignored) and fill in values.
# Production builds ignore these — they are bundled into debug builds only.

# Bundled dev key for Brave Search API. Engineers obtain their own key from
# https://brave.com/search/api/ and paste it here. Production users provide their
# own key via the Settings screen.
BRAVE_DEV_KEY=

# NOTE (PR #22): the AI model coordinates are no longer configured here. All
# models (Gemma LLM, classifier, embedder, desktop GGUF/mmproj, Vosk) download
# from the public R2 CDN with no auth — URLs + checksums are pinned directly in
# ModelInventory / AndroidAuxModels / DesktopModelStore / DesktopAuxModels.
# HuggingFace is no longer used.

# Release signing (all optional). When RELEASE_STORE_FILE is set, `:androidApp`'s
# release build is signed with this keystore so `./gradlew :androidApp:installRelease`
# installs directly. When these are left blank, the build falls back to the local
# Android debug keystore (~/.android/debug.keystore) so installRelease still works for
# on-device testing of the minified build — a debug-signed release is for LOCAL
# VERIFICATION ONLY, never for distribution (Play needs a real upload key). If no
# keystore exists at all the release is left unsigned.
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=
RELEASE_KEY_PASSWORD=
