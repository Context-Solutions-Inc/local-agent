<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- INTERNET only — Brave Search is the sole outbound dependency (PRD section 4.4). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Inference runs as a foregroundService during active generation so the OS does
         not kill the process while the user waits for streamed tokens. Android 14+
         requires a typed foregroundServiceType; 'specialUse' with a stated rationale
         is the right fit for on-device LLM inference (no other type matches). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- WorkManager-driven model download runs as a typed foreground worker
         (FOREGROUND_SERVICE_TYPE_DATA_SYNC) so the 2.58 GB Gemma artifact survives
         backgrounding without the OS reaping us mid-stream. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- PR #11 — AlarmFiringService plays the looping alarm sound while an
         alarm is ringing. mediaPlayback is the policy-correct FGS type for
         real audio output. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- WorkManager handles the model download in the background. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- PR #11 — alarm clock + timer scheduling.
         USE_EXACT_ALARM is install-granted for apps whose primary purpose is
         alarm-clock functionality (calendar / reminder / alarm). We use it
         instead of SCHEDULE_EXACT_ALARM so there's no runtime permission
         prompt. RECEIVE_BOOT_COMPLETED + ACTION_LOCKED_BOOT_COMPLETED let
         the boot receiver re-arm pending AlarmManager fires after a reboot
         or app upgrade. VIBRATE drives the alarm vibration pattern. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Continuous in-app dictation (SpeechRecognizer) records audio directly,
         so it needs RECORD_AUDIO (requested at runtime). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- PR #57 — scanning the desktop pairing QR uses the camera (the
         zxing-android-embedded scanner requests the permission at runtime). The
         camera isn't required for the app to function. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Speech-to-text: Android 11+ package visibility requires declaring the
         RecognitionService intent so SpeechRecognizer.isRecognitionAvailable()
         can see the system recognizer. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- Pixel 7 has 8GB RAM; we declare the app expects substantial heap for Gemma 4 E4B. -->
    <application
        android:name=".LocalAgentApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LocalAgent"
        android:largeHeap="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.LocalAgent">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".spike.SpikeActivity"
            android:exported="true"
            android:label="@string/spike_title"
            android:theme="@style/Theme.LocalAgent">
            <!-- Internal-only entry point. Disabled in release builds via PackageManager. -->
        </activity>

        <service
            android:name=".service.InferenceForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device LLM inference for the assistant; runs only while the user is actively waiting for a generated response." />
        </service>

        <!-- WorkManager runs all foreground workers through its bundled
             SystemForegroundService. Android 14+ requires that service to declare
             every foregroundServiceType it might invoke. ModelDownloadWorker
             calls setForeground with FOREGROUND_SERVICE_TYPE_DATA_SYNC, so we
             merge `dataSync` onto WorkManager's manifest entry here. Without
             this, startForeground throws IllegalArgumentException ("0x1 is not
             a subset of 0x0") and the worker process crashes immediately. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- PR #11 — AlarmFiringService loops the alarm sound + re-posts the
             notification every 10s while an alarm is ringing. mediaPlayback
             FGS type matches the looping ringtone playback. -->
        <service
            android:name=".service.clock.AlarmFiringService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- PR #11 — AlarmManager fires PendingIntent broadcasts here for both
             timers (ACTION_TIMER_FIRE) and alarms (ACTION_ALARM_FIRE). The
             receiver hands timers off to a single chime notification and
             starts AlarmFiringService for alarms. -->
        <receiver
            android:name=".service.clock.ClockEventReceiver"
            android:exported="false" />

        <!-- PR #11 — Snooze / Off-for-today / Dismiss buttons on the firing
             notifications route here. -->
        <receiver
            android:name=".service.clock.ClockActionReceiver"
            android:exported="false" />

        <!-- PR #11 — Re-arms persisted timers + alarms after a device boot or
             app upgrade (AlarmManager drops scheduled fires across both). -->
        <receiver
            android:name=".service.clock.ClockBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
