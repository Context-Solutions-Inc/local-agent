# Android / Gradle
# ============================================================================
.gradle/
build/
*/build/
captures/
.externalNativeBuild/
.cxx/
*.apk
*.aab
*.ap_
*.dex
*.class
local.properties
.kotlin/

# ============================================================================
# IDE
# ============================================================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
.fleet/
out/
.DS_Store

# ============================================================================
# Python (classifier-training)
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
.ipynb_checkpoints/

# ============================================================================
# Logs and runtime artifacts
# ============================================================================
*.log
logs/
**/stub-run.json
spike-results/
eval-results/
# Spike-run JSON pulled off-device via adb (per docs/SPIKE_RUNBOOK.md)
**/spike-*.json

# ============================================================================
# Eval runs — large training checkpoints + transient gate snapshots stay local.
# Keep the v1.0 baseline's metrics.json + REPORT.md committed so
# ct-regression-check has its baseline reference (see docs/M3_M4_HANDOFF.md §6).
# ============================================================================
eval/runs/**/*.pt
eval/runs/**/train.log
eval/runs/regression_check_candidate.json
eval/runs/phaseF_iter*/
eval/runs/phaseG_quantized_*/
eval/runs/smoke_*/

# Claude Code local session state
.claude/

# ============================================================================
# Xcode per-user state (iOS app, PR #41). The shared project + workspace + the
# SwiftPM Package.resolved ARE committed; per-user UI/breakpoint state is not.
# ============================================================================
**/xcuserdata/
*.xcuserstate
android-app/iosApp/**/DerivedData/
