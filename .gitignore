# ============================================================================
# Secrets — never committed
# ============================================================================
secrets.properties
secrets.local.properties
local.properties
**/google-services.json
**/firebase-app-distribution-service-credentials*.json
*.keystore
*.jks
*.p12
*.pem
.env
.env.*
!.env.example

# ============================================================================
# Model artifacts — too large for git, distributed via CDN/release storage
# ============================================================================
models/
*.litertmodel
*.tflite
*.task
*.gguf
*.safetensors
*.bin
*.onnx

# ============================================================================
# Dataset payloads — JSONL files distributed via release storage / LFS
# Manifests + schemas remain in repo
# ============================================================================
datasets/**/*.jsonl
datasets/**/*.parquet
!datasets/**/example.jsonl

